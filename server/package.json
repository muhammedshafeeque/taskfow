{
  "name": "server",
  "version": "1.0.0",
  "description": "Jira-like project management API",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && tsc-alias",
    "start": "node dist/index.js",
    "dev": "ts-node-dev -r tsconfig-paths/register --respawn src/index.ts",
    "create-super-admin": "ts-node -r dotenv/config src/scripts/create-super-admin.ts",
    "accept-invitations": "ts-node -r tsconfig-paths/register -r dotenv/config src/scripts/accept-invitations.ts",
    "seed-taskflow-roles": "ts-node -r tsconfig-paths/register -r dotenv/config src/scripts/seed-taskflow-roles.ts",
    "seed-org-customer-roles": "ts-node -r tsconfig-paths/register -r dotenv/config src/scripts/seed-org-customer-roles.ts",
    "migrate-permissions-to-dot": "ts-node -r tsconfig-paths/register -r dotenv/config src/scripts/migrate-permissions-to-dot.ts",
    "import-ado": "ts-node -r dotenv/config src/scripts/import-azure-devops.ts",
    "prebuild": "npm test",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --passWithNoTests"
  },
  "keywords": [],
  "author": "",
  "license": "GPL-3.0",
  "dependencies": {
    "@react-email/components": "^1.0.8",
    "@react-email/render": "^2.0.4",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.21.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.5.0",
    "morgan": "^1.10.1",
    "multer": "^2.1.0",
    "nodemailer": "^8.0.1",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-microsoft": "^2.1.0",
    "react": "^19.2.4",
    "socket.io": "^4.8.3",
    "web-push": "^3.6.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.9.0",
    "@types/nodemailer": "^7.0.11",
    "@types/passport": "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/web-push": "^3.6.4",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.5",
    "ts-node-dev": "^2.0.0",
    "tsc-alias": "^1.8.10",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.6.3"
  }
}
