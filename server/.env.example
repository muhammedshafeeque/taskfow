# -----------------------------------------------------------------------------
# Core (see src/config/env.ts)
# -----------------------------------------------------------------------------
PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/pm-tool

# -----------------------------------------------------------------------------
# JWT
# -----------------------------------------------------------------------------
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
IS_PUBLIC_SIGNUP_ENABLED=false
IS_EMAIL_PASSWORD_AUTH_ENABLED=true

# -----------------------------------------------------------------------------
# Frontend / links
# APP_URL: default base URL for the app (emails, Azure redirect fallback).
# FRONTEND_URL: used for user-invite email links; set to your SPA origin if unset breaks invites.
# -----------------------------------------------------------------------------
APP_URL=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# -----------------------------------------------------------------------------
# Email transport — set exactly ONE of IS_SMTP_ENABLED or IS_AZURE_GRAPH_ENABLED to true.
# If both are true, SMTP takes precedence.
# If neither is true, emails are silently skipped.
# -----------------------------------------------------------------------------

# -- Option A: SMTP (nodemailer) ----------------------------------------------
IS_SMTP_ENABLED=true
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=noreply@taskflow.local
# # Legacy aliases (also supported):
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-password
EMAIL_FROM=noreply@taskflow.local

# -- Option B: Azure Microsoft Graph API --------------------------------------
# These are SEPARATE from the Azure AD SSO credentials below — they can be a
# different app registration and/or a different tenant entirely.
IS_AZURE_GRAPH_ENABLED=true
AZURE_GRAPH_TENANT_ID=your-graph-tenant-id        # must be a real tenant ID, not "common"
AZURE_GRAPH_CLIENT_ID=your-graph-client-id
AZURE_GRAPH_CLIENT_SECRET=your-graph-client-secret
AZURE_GRAPH_FROM_EMAIL=noreply@yourdomain.com     # mailbox in your Graph tenant (user or shared)
# # The app registration must have Mail.Send *application* permission with admin consent.

# -- Option C: SendGrid API ----------------------------------------------------
IS_SENDGRID_ENABLED=false
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# -----------------------------------------------------------------------------
# Web Push (browser notifications)
# -----------------------------------------------------------------------------
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
IS_FIREBASE_PUSH_ENABLED=false
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# -----------------------------------------------------------------------------
# Enterprise: max registered users (omit or empty = no limit)
# -----------------------------------------------------------------------------
MAX_USERS=100

# -----------------------------------------------------------------------------
# Microsoft / Azure AD SSO (optional)
# -----------------------------------------------------------------------------
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=common
AZURE_REDIRECT_URI=http://localhost:5173/login
MS_USER_INFO_ENDPOINT=https://graph.microsoft.com/oidc/userinfo
MS_TOKEN_ENDPOINT=
AZURE_GRAPH_FROM_EMAIL=   # required when IS_AZURE_GRAPH_ENABLED=true

# -----------------------------------------------------------------------------
# create-super-admin script (npm run create-super-admin)
# Optional non-interactive values; otherwise the script prompts.
# -----------------------------------------------------------------------------
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=
SUPER_ADMIN_NAME=Super Admin

# -----------------------------------------------------------------------------
# import-ado script (npm run import-ado) — Azure DevOps work items → taskflow project
# -----------------------------------------------------------------------------
AZURE_DEVOPS_ORG=your-org
AZURE_DEVOPS_PROJECT=ADO-team-project-name
AZURE_DEVOPS_PAT=
IMPORT_REPORTER_EMAIL=admin@example.com
DEFAULT_WIQL=SELECT [System.Id] FROM WorkItems WHERE [System.TeamProject] = 'MyProject'

# -----------------------------------------------------------------------------
# Third-party integrations config (used by Workspace Settings > Integrations)
# Toggle with true/false and provide required keys.
# -----------------------------------------------------------------------------
IS_TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

IS_TEAMS_ENABLED=false
TEAMS_WEBHOOK_URL=
IS_TEAMS_GRAPH_ENABLED=false
TEAMS_GRAPH_TENANT_ID=
TEAMS_GRAPH_CLIENT_ID=
TEAMS_GRAPH_CLIENT_SECRET=
TEAMS_GRAPH_TEAM_ID=
TEAMS_GRAPH_CHANNEL_ID=

IS_SLACK_ENABLED=false
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_DEFAULT_CHANNEL=#alerts

IS_DISCORD_ENABLED=false
DISCORD_WEBHOOK_URL=

IS_WHATSAPP_ENABLED=false
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_DEFAULT_TO=

IS_S3_ENABLED=false
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=

IS_AZURE_BLOB_ENABLED=false
AZURE_BLOB_CONNECTION_STRING=
AZURE_BLOB_ACCOUNT_NAME=
AZURE_BLOB_ACCOUNT_KEY=
AZURE_BLOB_CONTAINER=

IS_SMS_ENABLED=false
SMS_PROVIDER=twilio
SMS_DEFAULT_TO=
# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
# Fast2SMS
FAST2SMS_API_KEY=
FAST2SMS_ROUTE=q
# WhatsToSMS
WHATSTOSMS_API_KEY=
WHATSTOSMS_SENDER_ID=

IS_JIRA_ENABLED=false
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=

IS_AZURE_DEVOPS_ENABLED=false
AZURE_DEVOPS_ORG_URL=
AZURE_DEVOPS_PAT=
AZURE_DEVOPS_PROJECT=
# # Legacy script key still supported in scripts:
# # AZURE_DEVOPS_ORG=your-org
#
IS_GITHUB_ENABLED=false
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# AI model providers
# -----------------------------------------------------------------------------
IS_OPENAI_ENABLED=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

IS_CLAUDE_ENABLED=false
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-3-5-sonnet-latest

IS_GROQ_ENABLED=false
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-70b-versatile

IS_MISTRAL_ENABLED=false
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-large-latest

# -----------------------------------------------------------------------------
# Google auth (OAuth)
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/oauth/google/callback

# -----------------------------------------------------------------------------
# Microsoft auth (OAuth)
# -----------------------------------------------------------------------------
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=common
MICROSOFT_CALLBACK_URL=http://localhost:5000/api/auth/oauth/microsoft/callback
